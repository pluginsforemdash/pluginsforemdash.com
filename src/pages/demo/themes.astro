---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;

const themes = [
	{ name: "lofi", desc: "Minimal and clean" },
	{ name: "dark", desc: "Classic dark mode" },
	{ name: "light", desc: "Clean and bright" },
	{ name: "cyberpunk", desc: "Neon and futuristic" },
	{ name: "synthwave", desc: "Retro 80s vibes" },
	{ name: "retro", desc: "Warm vintage feel" },
	{ name: "dracula", desc: "Purple dark theme" },
	{ name: "night", desc: "Deep blue dark" },
	{ name: "coffee", desc: "Warm brown tones" },
	{ name: "luxury", desc: "Gold on black" },
	{ name: "forest", desc: "Natural greens" },
	{ name: "cupcake", desc: "Soft pastels" },
	{ name: "bumblebee", desc: "Yellow and bold" },
	{ name: "emerald", desc: "Green and clean" },
	{ name: "corporate", desc: "Professional blue" },
	{ name: "valentine", desc: "Pink and romantic" },
	{ name: "halloween", desc: "Orange and dark" },
	{ name: "garden", desc: "Fresh and organic" },
	{ name: "aqua", desc: "Ocean blues" },
	{ name: "pastel", desc: "Soft and gentle" },
	{ name: "wireframe", desc: "Sketch-like" },
	{ name: "black", desc: "Pure black" },
	{ name: "nord", desc: "Cool nordic" },
	{ name: "sunset", desc: "Warm gradients" },
];
---

<Layout title="30+ Themes — Plugins for EmDash" description="Preview every DaisyUI theme available for the EmDash Commerce storefront.">
	<nav class="border-b border-border-subtle bg-surface/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
			<a href="/" class="flex items-center gap-2 text-lg font-bold">
				<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-sm font-black text-white">P</span>
				PluginsforEmDash
			</a>
			<div class="flex items-center gap-6">
				<a href="/demo" class="text-sm text-text-secondary hover:text-text-primary transition-colors">All Demos</a>
				<a href="https://github.com/pluginsforemdash/theme-store" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Get Theme (Free)</a>
			</div>
		</div>
	</nav>

	<section class="py-16">
		<div class="mx-auto max-w-6xl px-6">
			<div class="text-center mb-12">
				<span class="rounded-full bg-orange-500/10 px-3 py-1 text-xs font-medium text-orange-400 mb-4 inline-block">Free Theme</span>
				<h1 class="text-4xl font-bold tracking-tight">30+ DaisyUI Themes</h1>
				<p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">Every theme changes the entire storefront with one click. Your customers can pick their preferred look, or you set a default.</p>
			</div>

			<!-- Theme previews -->
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
				{themes.map((t) => (
					<div data-theme={t.name} class="rounded-xl border border-base-300 bg-base-100 p-4 text-base-content">
						<div class="flex items-center gap-2 mb-3">
							<div class="flex gap-1">
								<div class="w-3 h-3 rounded-full bg-primary"></div>
								<div class="w-3 h-3 rounded-full bg-secondary"></div>
								<div class="w-3 h-3 rounded-full bg-accent"></div>
							</div>
							<span class="font-semibold text-sm capitalize">{t.name}</span>
						</div>
						<p class="text-xs opacity-60 mb-3">{t.desc}</p>
						<div class="flex gap-2">
							<div class="rounded bg-primary px-2 py-1 text-primary-content text-xs">Button</div>
							<div class="rounded bg-secondary px-2 py-1 text-secondary-content text-xs">Badge</div>
							<div class="rounded bg-accent px-2 py-1 text-accent-content text-xs">Accent</div>
						</div>
						<div class="mt-3 rounded bg-base-200 p-2">
							<div class="text-xs font-medium">Product Card</div>
							<div class="text-xs opacity-60">$29.99</div>
						</div>
					</div>
				))}
			</div>

			<div class="mt-12 text-center">
				<p class="text-text-secondary mb-4">Store owners set their default theme. Customers can optionally switch via the theme picker.</p>
				<a href="https://github.com/pluginsforemdash/theme-store" class="inline-block rounded-xl bg-brand-600 px-8 py-3.5 font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-500 transition-all">
					Get the Theme — Free
				</a>
			</div>
		</div>
	</section>
</Layout>
