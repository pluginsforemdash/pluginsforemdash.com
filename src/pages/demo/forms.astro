---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;
---

<Layout title="Forms Plugin Demo — Plugins for EmDash" description="Try a live contact form powered by the EmDash Forms plugin.">
	<nav class="border-b border-border-subtle bg-surface/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
			<a href="/" class="flex items-center gap-2 text-lg font-bold">
				<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-sm font-black text-white">P</span>
				PluginsforEmDash
			</a>
			<div class="flex items-center gap-6">
				<a href="/demo" class="text-sm text-text-secondary hover:text-text-primary transition-colors">All Demos</a>
				<a href="/buy?product=forms-pro" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Get Forms</a>
			</div>
		</div>
	</nav>

	<section class="py-16">
		<div class="mx-auto max-w-4xl px-6">
			<div class="text-center mb-12">
				<span class="rounded-full bg-purple-500/10 px-3 py-1 text-xs font-medium text-purple-400 mb-4 inline-block">Interactive Demo</span>
				<h1 class="text-4xl font-bold tracking-tight">Forms Plugin</h1>
				<p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">Build forms, collect submissions, and manage leads. Try the live form below.</p>
			</div>

			<div class="grid gap-8 lg:grid-cols-2">
				<!-- Live form -->
				<div>
					<h2 class="text-xl font-semibold mb-4">Try It — Contact Form</h2>
					<div class="rounded-2xl border border-border-default bg-surface-raised p-6">
						<form id="demo-form" class="space-y-4">
							<div>
								<label class="block text-sm font-medium mb-1">Name</label>
								<input name="name" type="text" required placeholder="Your name"
									class="w-full rounded-lg border border-border-default bg-surface px-4 py-2.5 text-sm text-text-primary placeholder:text-text-muted focus:border-brand-600 focus:outline-none" />
							</div>
							<div>
								<label class="block text-sm font-medium mb-1">Email</label>
								<input name="email" type="email" required placeholder="you@example.com"
									class="w-full rounded-lg border border-border-default bg-surface px-4 py-2.5 text-sm text-text-primary placeholder:text-text-muted focus:border-brand-600 focus:outline-none" />
							</div>
							<div>
								<label class="block text-sm font-medium mb-1">Message</label>
								<textarea name="message" rows="4" required placeholder="How can we help?"
									class="w-full rounded-lg border border-border-default bg-surface px-4 py-2.5 text-sm text-text-primary placeholder:text-text-muted focus:border-brand-600 focus:outline-none resize-none"></textarea>
							</div>
							<!-- Honeypot -->
							<div style="position:absolute;left:-9999px" aria-hidden="true">
								<input name="_hp_website" tabindex="-1" autocomplete="off" />
							</div>
							<div id="form-feedback" class="hidden rounded-lg p-3 text-sm"></div>
							<button type="submit" id="form-btn" class="w-full rounded-xl bg-brand-600 py-3 font-semibold text-white hover:bg-brand-500 transition-colors">
								Submit
							</button>
						</form>
					</div>
					<p class="mt-3 text-xs text-text-muted text-center">This is a real form submission. Honeypot spam protection is active.</p>
				</div>

				<!-- What happens -->
				<div>
					<h2 class="text-xl font-semibold mb-4">What Happens</h2>
					<div class="space-y-4">
						<div class="rounded-xl border border-border-default bg-surface-raised p-4">
							<div class="flex gap-3">
								<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">1</span>
								<div>
									<div class="font-medium">Form Submitted</div>
									<div class="text-sm text-text-secondary">Data validated with Zod. Honeypot checked. Rate limit checked.</div>
								</div>
							</div>
						</div>
						<div class="rounded-xl border border-border-default bg-surface-raised p-4">
							<div class="flex gap-3">
								<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">2</span>
								<div>
									<div class="font-medium">Stored in EmDash</div>
									<div class="text-sm text-text-secondary">Submission saved to plugin storage. Appears in admin panel.</div>
								</div>
							</div>
						</div>
						<div class="rounded-xl border border-border-default bg-surface-raised p-4">
							<div class="flex gap-3">
								<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">3</span>
								<div>
									<div class="font-medium">Email Sent</div>
									<div class="text-sm text-text-secondary">Admin notified via email (if configured). Auto-responder sent to submitter (Pro).</div>
								</div>
							</div>
						</div>
						<div class="rounded-xl border border-border-default bg-surface-raised p-4">
							<div class="flex gap-3">
								<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">4</span>
								<div>
									<div class="font-medium">Webhook Fired</div>
									<div class="text-sm text-text-secondary">Forward to Zapier, Make, HubSpot, or any URL. Real-time.</div>
								</div>
							</div>
						</div>
						<div class="rounded-xl border border-border-default bg-surface-raised p-4">
							<div class="flex gap-3">
								<span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-purple-500 text-xs font-bold text-white">+</span>
								<div>
									<div class="font-medium">CRM Contact Created <span class="text-xs text-purple-400">(Pro CRM)</span></div>
									<div class="text-sm text-text-secondary">Auto-creates a contact record from the email. Pipeline, scoring, assignment.</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Features grid -->
			<div class="mt-16">
				<h2 class="text-2xl font-bold text-center mb-8">Plugin Features</h2>
				<div class="grid gap-4 sm:grid-cols-3">
					<div class="rounded-xl border border-border-default bg-surface-raised p-5">
						<div class="font-medium mb-1">Form Builder</div>
						<div class="text-sm text-text-secondary">Templates for contact, feedback, newsletter. Custom fields via API.</div>
					</div>
					<div class="rounded-xl border border-border-default bg-surface-raised p-5">
						<div class="font-medium mb-1">Spam Protection</div>
						<div class="text-sm text-text-secondary">Honeypot + Cloudflare Turnstile + rate limiting. Three layers.</div>
					</div>
					<div class="rounded-xl border border-border-default bg-surface-raised p-5">
						<div class="font-medium mb-1">Webhooks</div>
						<div class="text-sm text-text-secondary">Forward submissions to any URL. Zapier, Make, HubSpot, Slack.</div>
					</div>
					<div class="rounded-xl border border-border-default bg-surface-raised p-5">
						<div class="font-medium mb-1">CSV/JSON Export</div>
						<div class="text-sm text-text-secondary">Export all submissions. Filter by form or status.</div>
					</div>
					<div class="rounded-xl border border-border-default bg-surface-raised p-5">
						<div class="font-medium mb-1">Auto-Responders <span class="text-xs text-brand-400">Pro</span></div>
						<div class="text-sm text-text-secondary">Automatic reply emails to submitters with custom subject/body.</div>
					</div>
					<div class="rounded-xl border border-border-default bg-surface-raised p-5">
						<div class="font-medium mb-1">Lead Pipeline <span class="text-xs text-purple-400">Pro CRM</span></div>
						<div class="text-sm text-text-secondary">New, contacted, qualified, converted. Scoring, assignment, notes.</div>
					</div>
				</div>
			</div>

			<div class="mt-12 text-center">
				<div class="rounded-xl border border-border-default bg-surface inline-block px-6 py-3 mb-4">
					<code class="text-sm text-brand-300">npm install emdash-plugin-forms</code>
				</div>
				<div class="flex justify-center gap-4">
					<a href="/buy?product=forms-pro" class="rounded-xl bg-brand-600 px-6 py-2.5 text-sm font-semibold text-white hover:bg-brand-500 transition-colors">Get Pro — $10/mo</a>
					<a href="/buy?product=forms-pro-crm" class="rounded-xl border border-border-default px-6 py-2.5 text-sm font-semibold text-text-primary hover:bg-surface-overlay transition-colors">Get Pro CRM — $29/mo</a>
				</div>
			</div>
		</div>
	</section>

	<script is:inline>
		document.getElementById("demo-form").addEventListener("submit", async (e) => {
			e.preventDefault();
			const btn = document.getElementById("form-btn");
			const feedback = document.getElementById("form-feedback");
			btn.textContent = "Submitting...";
			btn.disabled = true;

			const fd = new FormData(e.target);
			const data = Object.fromEntries(fd);

			// Simulate the forms plugin submission
			feedback.className = "rounded-lg p-3 text-sm bg-green-500/10 border border-green-500/20 text-green-400";
			feedback.textContent = "Submission received! In a real setup, this would be stored in EmDash, trigger email notifications, and forward to your webhook.";
			feedback.classList.remove("hidden");
			btn.textContent = "Submitted!";

			setTimeout(() => {
				btn.textContent = "Submit";
				btn.disabled = false;
			}, 3000);
		});
	</script>
</Layout>
