---
import Layout from "../../layouts/Layout.astro";
export const prerender = false;
const demoUrl = "https://demo.pluginsforemdash.com";
---

<Layout title="Commerce Store Demo — Plugins for EmDash" description="Live demo of the EmDash Commerce plugin storefront with DaisyUI themes.">
	<nav class="border-b border-border-subtle bg-surface/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
			<a href="/" class="flex items-center gap-2 text-lg font-bold">
				<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-sm font-black text-white">P</span>
				PluginsforEmDash
			</a>
			<div class="flex items-center gap-6">
				<a href="/demo" class="text-sm text-text-secondary hover:text-text-primary transition-colors">All Demos</a>
				<a href="/buy?product=commerce-pro" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Get Commerce</a>
			</div>
		</div>
	</nav>

	<section class="py-16">
		<div class="mx-auto max-w-6xl px-6">
			<div class="text-center mb-12">
				<span class="rounded-full bg-green-500/10 px-3 py-1 text-xs font-medium text-green-400 mb-4 inline-block">Live Demo</span>
				<h1 class="text-4xl font-bold tracking-tight">Commerce Storefront</h1>
				<p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">A complete e-commerce storefront powered by the Commerce plugin and DaisyUI. 30+ themes, product pages, cart, checkout — all working.</p>
			</div>

			<!-- Feature highlights -->
			<div class="grid gap-6 sm:grid-cols-3 mb-12">
				<div class="rounded-xl border border-border-default bg-surface-raised p-6 text-center">
					<div class="text-3xl font-bold text-brand-400">13</div>
					<div class="text-sm text-text-secondary mt-1">Demo Products</div>
				</div>
				<div class="rounded-xl border border-border-default bg-surface-raised p-6 text-center">
					<div class="text-3xl font-bold text-brand-400">4</div>
					<div class="text-sm text-text-secondary mt-1">Categories</div>
				</div>
				<div class="rounded-xl border border-border-default bg-surface-raised p-6 text-center">
					<div class="text-3xl font-bold text-brand-400">30+</div>
					<div class="text-sm text-text-secondary mt-1">DaisyUI Themes</div>
				</div>
			</div>

			<!-- Pages showcase -->
			<div class="space-y-8">
				<div class="rounded-2xl border border-border-default bg-surface-raised p-8">
					<h2 class="text-xl font-semibold mb-4">What's in the demo</h2>
					<div class="grid gap-4 sm:grid-cols-2">
						<div class="flex gap-3">
							<span class="text-green-400 mt-1">&#10003;</span>
							<div>
								<div class="font-medium">Homepage</div>
								<div class="text-sm text-text-secondary">Hero section, featured products grid, blog posts</div>
							</div>
						</div>
						<div class="flex gap-3">
							<span class="text-green-400 mt-1">&#10003;</span>
							<div>
								<div class="font-medium">Shop Page</div>
								<div class="text-sm text-text-secondary">Product grid with category tabs, sale badges, stock status</div>
							</div>
						</div>
						<div class="flex gap-3">
							<span class="text-green-400 mt-1">&#10003;</span>
							<div>
								<div class="font-medium">Product Detail</div>
								<div class="text-sm text-text-secondary">Images, variants, pricing, add to cart, related products</div>
							</div>
						</div>
						<div class="flex gap-3">
							<span class="text-green-400 mt-1">&#10003;</span>
							<div>
								<div class="font-medium">Shopping Cart</div>
								<div class="text-sm text-text-secondary">Quantity controls, discount codes, order summary</div>
							</div>
						</div>
						<div class="flex gap-3">
							<span class="text-green-400 mt-1">&#10003;</span>
							<div>
								<div class="font-medium">Checkout</div>
								<div class="text-sm text-text-secondary">Contact info, shipping address, Stripe redirect</div>
							</div>
						</div>
						<div class="flex gap-3">
							<span class="text-green-400 mt-1">&#10003;</span>
							<div>
								<div class="font-medium">Theme Switcher</div>
								<div class="text-sm text-text-secondary">Click the palette icon to switch between 30+ themes instantly</div>
							</div>
						</div>
					</div>
				</div>

				<div class="text-center">
					<a href={demoUrl} target="_blank" class="inline-block rounded-xl bg-brand-600 px-8 py-3.5 font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-500 transition-all">
						Open Live Demo Store
					</a>
					<p class="mt-3 text-sm text-text-muted">Opens in a new tab. Use test card 4242 4242 4242 4242 for checkout.</p>
				</div>
			</div>

			<!-- Install CTA -->
			<div class="mt-16 rounded-2xl border border-brand-600/50 bg-surface-raised p-8 text-center">
				<h2 class="text-2xl font-bold mb-2">Ready to build your store?</h2>
				<p class="text-text-secondary mb-6">Clone the theme and start selling in minutes.</p>
				<div class="rounded-xl border border-border-default bg-surface inline-block px-6 py-3 mb-4">
					<code class="text-sm text-brand-300">git clone https://github.com/pluginsforemdash/theme-store.git my-store</code>
				</div>
				<div class="flex justify-center gap-4">
					<a href="https://github.com/pluginsforemdash/theme-store" class="text-sm text-text-secondary hover:text-text-primary">GitHub</a>
					<a href="https://github.com/pluginsforemdash/commerce" class="text-sm text-text-secondary hover:text-text-primary">Commerce Plugin</a>
					<a href="/buy?product=commerce-pro" class="text-sm font-medium text-brand-400 hover:text-brand-300">Get Pro</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
