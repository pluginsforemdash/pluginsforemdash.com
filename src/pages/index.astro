---
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Plugins for EmDash — Lead Capture, Helpdesk & Customer Service for EmDash CMS"
	description="Professional plugins for EmDash CMS. Capture leads, manage support tickets, and run customer service — all from your EmDash admin panel."
>
	<!-- Nav -->
	<nav class="fixed top-0 left-0 right-0 z-50 border-b border-border-subtle bg-surface/80 backdrop-blur-xl">
		<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
			<a href="/" class="flex items-center gap-2 text-lg font-bold">
				<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-sm font-black text-white">P</span>
				PluginsforEmDash
			</a>
			<div class="hidden items-center gap-8 sm:flex">
				<a href="#plugins" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Plugins</a>
				<a href="#pricing" class="text-sm text-text-secondary hover:text-text-primary transition-colors">Pricing</a>
				<a href="#faq" class="text-sm text-text-secondary hover:text-text-primary transition-colors">FAQ</a>
				<a href="#pricing" class="rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white hover:bg-brand-500 transition-colors">Get Started</a>
			</div>
		</div>
	</nav>

	<!-- Hero -->
	<section class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
		<div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--color-brand-600)_0%,_transparent_60%)] opacity-15"></div>
		<div class="relative mx-auto max-w-4xl px-6 text-center">
			<div class="mb-6 inline-flex items-center gap-2 rounded-full border border-border-default bg-surface-raised px-4 py-1.5 text-sm text-text-secondary">
				<span class="h-2 w-2 rounded-full bg-green-400 animate-pulse"></span>
				Now available for EmDash CMS v0.1+
			</div>
			<h1 class="text-4xl font-bold leading-tight tracking-tight sm:text-6xl lg:text-7xl">
				Grow your business with
				<span class="bg-gradient-to-r from-brand-400 to-brand-600 bg-clip-text text-transparent">EmDash plugins</span>
			</h1>
			<p class="mx-auto mt-6 max-w-2xl text-lg text-text-secondary sm:text-xl">
				Lead capture, helpdesk, and customer service &mdash; purpose-built for EmDash CMS.
				Install in seconds. No separate SaaS subscriptions. Your data stays on your infrastructure.
			</p>
			<div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
				<a href="#pricing" class="w-full rounded-xl bg-brand-600 px-8 py-3.5 text-center font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-500 transition-all sm:w-auto">
					View Pricing
				</a>
				<a href="#plugins" class="w-full rounded-xl border border-border-default bg-surface-raised px-8 py-3.5 text-center font-semibold text-text-primary hover:bg-surface-overlay transition-all sm:w-auto">
					See All Plugins
				</a>
			</div>
		</div>
	</section>

	<!-- Trust bar -->
	<section class="border-y border-border-subtle bg-surface-raised/50 py-8">
		<div class="mx-auto flex max-w-4xl flex-wrap items-center justify-center gap-x-12 gap-y-4 px-6 text-sm text-text-muted">
			<span>Sandboxed &amp; Secure</span>
			<span>One-Click Install</span>
			<span>Works on Cloudflare Workers &amp; Node.js</span>
			<span>Your Data, Your Server</span>
		</div>
	</section>

	<!-- Plugins -->
	<section id="plugins" class="py-20 sm:py-28">
		<div class="mx-auto max-w-6xl px-6">
			<div class="text-center">
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">The plugin suite</h2>
				<p class="mt-4 text-lg text-text-secondary">Everything you need to turn your EmDash site into a business platform.</p>
			</div>

			<div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
				<!-- Leads -->
				<div class="rounded-2xl border border-border-default bg-surface-raised p-8 transition-all hover:border-brand-600/50">
					<div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-brand-600/10 text-brand-400">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
					</div>
					<div class="mb-2 flex items-center gap-2">
						<h3 class="text-xl font-semibold">Leads</h3>
						<span class="rounded-full bg-green-500/10 px-2 py-0.5 text-xs font-medium text-green-400">Available Now</span>
					</div>
					<p class="mb-6 text-text-secondary">
						Capture leads from any page. Manage your pipeline with statuses, assignments, notes, and email notifications. Export to CSV or forward to your CRM via webhooks.
					</p>
					<ul class="space-y-2 text-sm text-text-secondary">
						<li class="flex items-start gap-2"><span class="text-brand-400 mt-1">&#10003;</span> Embeddable capture forms</li>
						<li class="flex items-start gap-2"><span class="text-brand-400 mt-1">&#10003;</span> Honeypot + Turnstile spam protection</li>
						<li class="flex items-start gap-2"><span class="text-brand-400 mt-1">&#10003;</span> Pipeline dashboard</li>
						<li class="flex items-start gap-2"><span class="text-brand-400 mt-1">&#10003;</span> Email notifications + CRM webhooks</li>
						<li class="flex items-start gap-2"><span class="text-brand-400 mt-1">&#10003;</span> CSV/JSON export</li>
					</ul>
				</div>

				<!-- Helpdesk -->
				<div class="rounded-2xl border border-border-default bg-surface-raised p-8 transition-all hover:border-orange-500/50">
					<div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-orange-500/10 text-orange-400">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z"></path></svg>
					</div>
					<div class="mb-2 flex items-center gap-2">
						<h3 class="text-xl font-semibold">Helpdesk</h3>
						<span class="rounded-full bg-orange-500/10 px-2 py-0.5 text-xs font-medium text-orange-400">Coming Soon</span>
					</div>
					<p class="mb-6 text-text-secondary">
						A full ticket system inside EmDash. Customers submit tickets from your site, your team manages them in the admin panel. Track SLAs, assign agents, and resolve issues.
					</p>
					<ul class="space-y-2 text-sm text-text-secondary">
						<li class="flex items-start gap-2"><span class="text-orange-400 mt-1">&#10003;</span> Public ticket submission</li>
						<li class="flex items-start gap-2"><span class="text-orange-400 mt-1">&#10003;</span> Priority levels &amp; SLA tracking</li>
						<li class="flex items-start gap-2"><span class="text-orange-400 mt-1">&#10003;</span> Agent assignment &amp; internal notes</li>
						<li class="flex items-start gap-2"><span class="text-orange-400 mt-1">&#10003;</span> Email notifications on updates</li>
						<li class="flex items-start gap-2"><span class="text-orange-400 mt-1">&#10003;</span> Resolution metrics &amp; reporting</li>
					</ul>
				</div>

				<!-- Customer Service Desk -->
				<div class="rounded-2xl border border-border-default bg-surface-raised p-8 transition-all hover:border-purple-500/50">
					<div class="mb-4 flex h-12 w-12 items-center justify-center rounded-xl bg-purple-500/10 text-purple-400">
						<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
					</div>
					<div class="mb-2 flex items-center gap-2">
						<h3 class="text-xl font-semibold">Customer Service Desk</h3>
						<span class="rounded-full bg-purple-500/10 px-2 py-0.5 text-xs font-medium text-purple-400">Coming Soon</span>
					</div>
					<p class="mb-6 text-text-secondary">
						A unified service desk combining live chat, knowledge base, and ticket escalation. Give your customers the support experience they expect.
					</p>
					<ul class="space-y-2 text-sm text-text-secondary">
						<li class="flex items-start gap-2"><span class="text-purple-400 mt-1">&#10003;</span> Embeddable live chat widget</li>
						<li class="flex items-start gap-2"><span class="text-purple-400 mt-1">&#10003;</span> Knowledge base with search</li>
						<li class="flex items-start gap-2"><span class="text-purple-400 mt-1">&#10003;</span> Chat-to-ticket escalation</li>
						<li class="flex items-start gap-2"><span class="text-purple-400 mt-1">&#10003;</span> Customer satisfaction surveys</li>
						<li class="flex items-start gap-2"><span class="text-purple-400 mt-1">&#10003;</span> Team inbox with collision detection</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- How It Works -->
	<section class="border-y border-border-subtle bg-surface-raised/30 py-20 sm:py-28">
		<div class="mx-auto max-w-4xl px-6">
			<div class="text-center">
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Up and running in 60 seconds</h2>
				<p class="mt-4 text-lg text-text-secondary">Standard EmDash plugins. No external services to set up.</p>
			</div>

			<div class="mt-16 space-y-12">
				<div class="flex gap-6">
					<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">1</div>
					<div>
						<h3 class="text-lg font-semibold">Install the plugin</h3>
						<div class="mt-3 rounded-xl border border-border-default bg-surface p-4">
							<code class="text-sm text-brand-300">npm install emdash-plugin-leads</code>
						</div>
					</div>
				</div>

				<div class="flex gap-6">
					<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">2</div>
					<div>
						<h3 class="text-lg font-semibold">Add it to your config</h3>
						<div class="mt-3 rounded-xl border border-border-default bg-surface p-4 overflow-x-auto">
							<pre class="text-sm text-text-secondary">import &#123; leadsPlugin &#125; from "emdash-plugin-leads";

export default defineConfig(&#123;
  integrations: [
    emdash(&#123;
      plugins: [leadsPlugin()],
    &#125;),
  ],
&#125;);</pre>
						</div>
					</div>
				</div>

				<div class="flex gap-6">
					<div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-brand-600 text-sm font-bold text-white">3</div>
					<div>
						<h3 class="text-lg font-semibold">Start capturing leads</h3>
						<p class="mt-1 text-text-secondary">
							The admin panel gets a new Leads section with pipeline management, and a public API endpoint is ready for your forms. Paste the embed code on any page.
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Pricing -->
	<section id="pricing" class="py-20 sm:py-28">
		<div class="mx-auto max-w-5xl px-6">
			<div class="text-center">
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Simple pricing</h2>
				<p class="mt-4 text-lg text-text-secondary">Every plugin is free to use. Pay only if you want managed email delivery.</p>
			</div>

			<div class="mt-16 grid gap-8 sm:grid-cols-2 sm:max-w-3xl sm:mx-auto">
				<!-- Free -->
				<div class="rounded-2xl border border-border-default bg-surface-raised p-8">
					<h3 class="text-lg font-semibold">Free</h3>
					<div class="mt-4 flex items-baseline gap-1">
						<span class="text-4xl font-bold">$0</span>
						<span class="text-text-muted">/forever</span>
					</div>
					<p class="mt-4 text-sm text-text-secondary">Full plugin functionality. Bring your own Resend API key for email notifications.</p>
					<ul class="mt-8 space-y-3 text-sm text-text-secondary">
						<li class="flex items-start gap-3"><span class="text-brand-400">&#10003;</span> All plugin features</li>
						<li class="flex items-start gap-3"><span class="text-brand-400">&#10003;</span> Unlimited leads</li>
						<li class="flex items-start gap-3"><span class="text-brand-400">&#10003;</span> Spam protection (honeypot + Turnstile)</li>
						<li class="flex items-start gap-3"><span class="text-brand-400">&#10003;</span> CRM webhook forwarding</li>
						<li class="flex items-start gap-3"><span class="text-brand-400">&#10003;</span> Export (CSV/JSON)</li>
						<li class="flex items-start gap-3"><span class="text-brand-400">&#10003;</span> Email via your own Resend key</li>
					</ul>
					<a href="https://github.com/pluginsforemdash/leads" class="mt-8 block rounded-xl border border-border-default bg-surface py-3 text-center text-sm font-semibold text-text-primary hover:bg-surface-overlay transition-colors">
						Install Free
					</a>
				</div>

				<!-- Pro -->
				<div class="relative rounded-2xl border-2 border-brand-600 bg-surface-raised p-8">
					<div class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-brand-600 px-3 py-0.5 text-xs font-semibold text-white">
						Most Popular
					</div>
					<h3 class="text-lg font-semibold">Pro</h3>
					<div class="mt-4 flex items-baseline gap-1">
						<span class="text-4xl font-bold">$10</span>
						<span class="text-text-muted">/month</span>
					</div>
					<p class="mt-4 text-sm text-text-secondary">Everything in Free, plus managed email delivery. No API keys to set up.</p>
					<ul class="mt-8 space-y-3 text-sm">
						<li class="flex items-start gap-3 text-text-primary font-medium"><span class="text-brand-400">&#10003;</span> Everything in Free</li>
						<li class="flex items-start gap-3 text-text-secondary"><span class="text-brand-400">&#10003;</span> Managed email delivery (no setup)</li>
						<li class="flex items-start gap-3 text-text-secondary"><span class="text-brand-400">&#10003;</span> Up to 5,000 emails/month</li>
						<li class="flex items-start gap-3 text-text-secondary"><span class="text-brand-400">&#10003;</span> Priority support</li>
						<li class="flex items-start gap-3 text-text-secondary"><span class="text-brand-400">&#10003;</span> Early access to new plugins</li>
						<li class="flex items-start gap-3 text-text-secondary"><span class="text-brand-400">&#10003;</span> Custom from: email address</li>
					</ul>
					<a href="#" class="mt-8 block rounded-xl bg-brand-600 py-3 text-center text-sm font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-500 transition-colors">
						Get Pro License
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Why not SaaS? -->
	<section class="border-y border-border-subtle bg-surface-raised/30 py-20 sm:py-28">
		<div class="mx-auto max-w-4xl px-6">
			<div class="text-center">
				<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">Why plugins instead of SaaS?</h2>
			</div>

			<div class="mt-12 grid gap-8 sm:grid-cols-2">
				<div class="rounded-xl border border-border-default bg-surface-raised p-6">
					<h3 class="font-semibold text-red-400">SaaS lead tools</h3>
					<ul class="mt-4 space-y-2 text-sm text-text-secondary">
						<li>$29-$99/mo per tool</li>
						<li>Data on someone else's servers</li>
						<li>Another login, another dashboard</li>
						<li>JavaScript embeds that slow your site</li>
						<li>GDPR headaches with third-party processors</li>
					</ul>
				</div>
				<div class="rounded-xl border border-brand-600/50 bg-surface-raised p-6">
					<h3 class="font-semibold text-brand-400">EmDash plugins</h3>
					<ul class="mt-4 space-y-2 text-sm text-text-secondary">
						<li>Free or $10/mo for everything</li>
						<li>Data stays on your Cloudflare account</li>
						<li>One admin panel for content + business tools</li>
						<li>Server-rendered, zero client-side bloat</li>
						<li>First-party data collection, no third parties</li>
					</ul>
				</div>
			</div>
		</div>
	</section>

	<!-- FAQ -->
	<section id="faq" class="py-20 sm:py-28">
		<div class="mx-auto max-w-3xl px-6">
			<h2 class="text-center text-3xl font-bold tracking-tight sm:text-4xl">FAQ</h2>

			<div class="mt-12 space-y-8">
				<div>
					<h3 class="font-semibold">Do I need to pay to use the plugins?</h3>
					<p class="mt-2 text-text-secondary">No. Every plugin is fully functional for free. The $10/mo Pro plan adds managed email delivery so you don't need to set up your own Resend account.</p>
				</div>
				<div>
					<h3 class="font-semibold">What is EmDash CMS?</h3>
					<p class="mt-2 text-text-secondary">EmDash is a new open-source CMS by Cloudflare, built on Astro. Think of it as the modern successor to WordPress &mdash; serverless, type-safe, with sandboxed plugins. Our plugins extend it with business functionality.</p>
				</div>
				<div>
					<h3 class="font-semibold">Where is my data stored?</h3>
					<p class="mt-2 text-text-secondary">All plugin data is stored in your EmDash database (Cloudflare D1, SQLite, or PostgreSQL &mdash; whatever you configured). We never see or store your data. The Pro plan only handles email delivery.</p>
				</div>
				<div>
					<h3 class="font-semibold">Can I use my own email provider?</h3>
					<p class="mt-2 text-text-secondary">Yes. On the free plan, paste your Resend API key in the plugin settings and email notifications work immediately. You can also skip email entirely and use webhook forwarding to tools like Zapier or Make.</p>
				</div>
				<div>
					<h3 class="font-semibold">Do the plugins work outside Cloudflare?</h3>
					<p class="mt-2 text-text-secondary">Yes. EmDash runs on any Node.js server with SQLite. Our plugins use the standard plugin API and work everywhere EmDash runs. Sandboxed mode (isolate security) is Cloudflare-only, but trusted mode works on any platform.</p>
				</div>
				<div>
					<h3 class="font-semibold">When are the Helpdesk and Customer Service plugins coming?</h3>
					<p class="mt-2 text-text-secondary">We're building them now. Pro subscribers get early access. Join the waitlist by signing up for a Pro plan or following us for updates.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA -->
	<section class="border-t border-border-subtle bg-surface-raised/30 py-20 sm:py-28">
		<div class="mx-auto max-w-3xl px-6 text-center">
			<h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
				Start capturing leads today
			</h2>
			<p class="mt-4 text-lg text-text-secondary">
				Install the Leads plugin in under a minute. No credit card required.
			</p>
			<div class="mt-8">
				<a href="#pricing" class="inline-block rounded-xl bg-brand-600 px-8 py-3.5 text-center font-semibold text-white shadow-lg shadow-brand-600/25 hover:bg-brand-500 transition-all">
					Get Started
				</a>
			</div>
			<div class="mt-6 rounded-xl border border-border-default bg-surface inline-block px-6 py-3">
				<code class="text-sm text-brand-300">npm install emdash-plugin-leads</code>
			</div>
		</div>
	</section>

	<!-- Footer -->
	<footer class="border-t border-border-subtle py-12">
		<div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-4 px-6 sm:flex-row">
			<div class="flex items-center gap-2 text-sm text-text-muted">
				<span class="flex h-6 w-6 items-center justify-center rounded bg-brand-600 text-xs font-black text-white">P</span>
				Plugins for EmDash
			</div>
			<div class="flex gap-6 text-sm text-text-muted">
				<a href="#plugins" class="hover:text-text-secondary transition-colors">Plugins</a>
				<a href="#pricing" class="hover:text-text-secondary transition-colors">Pricing</a>
				<a href="#faq" class="hover:text-text-secondary transition-colors">FAQ</a>
				<a href="mailto:hello@pluginsforemdash.com" class="hover:text-text-secondary transition-colors">Contact</a>
			</div>
		</div>
	</footer>
</Layout>
